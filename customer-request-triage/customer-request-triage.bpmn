      <bpmndi:BPMNShape id="End_InvalidRequest_di" bpmnElement="End_InvalidRequest">
        <dc:Bounds x="302" y="460" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_MissingOrderId_di" bpmnElement="End_MissingOrderId">
        <dc:Bounds x="632" y="460" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="609" y="496" width="83" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleOther_di" bpmnElement="Task_HandleOther">
        <dc:Bounds x="600" y="550" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Other_di" bpmnElement="End_Other">
