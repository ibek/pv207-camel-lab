          <dc:Bounds x="754" y="608" width="53" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleCancel_di" bpmnElement="Task_HandleCancel">
        <dc:Bounds x="600" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Cancel_di" bpmnElement="End_Cancel">
        <dc:Bounds x="762" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="756" y="248" width="49" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Boundary_MissingOrderId_di" bpmnElement="Boundary_MissingOrderId">
        <dc:Bounds x="632" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Boundary_InvalidRequest_di" bpmnElement="Boundary_InvalidRequest">
        <dc:Bounds x="302" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_StartToTriage_di" bpmnElement="Flow_StartToTriage">
        <di:waypoint x="198" y="360" />
        <di:waypoint x="270" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TriageToGateway_di" bpmnElement="Flow_TriageToGateway">
        <di:waypoint x="370" y="360" />
        <di:waypoint x="455" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Cancel_di" bpmnElement="Flow_Cancel">
        <di:waypoint x="480" y="335" />
        <di:waypoint x="480" y="230" />
        <di:waypoint x="600" y="230" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="497" y="213" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Refund_di" bpmnElement="Flow_Refund">
        <di:waypoint x="505" y="360" />
